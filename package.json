{
  "name": "pi-fzf-files",
  "version": "0.1.0",
  "description": "Replace Pi's @ file autocomplete with a pure TypeScript fzf-style fuzzy finder.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "autocomplete",
    "fzf",
    "fuzzy",
    "files"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src/",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "echo 'nothing to build'",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@earendil-works/pi-tui": "^0.79.4",
    "@types/bun": "^1.2.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
